{
    "name": "pnpm-monorepo-project",
    "keywords": [],
    "author": "",
    "license": "ISC",
    "description": "",
    "version": "1.0.0",
    "main": "index.js",
    "private": true,
    "type": "module",
    "scripts": {
        "admin:dev": "pnpm -F admin dev",
        "admin:build": "pnpm -F admin build",
        "dashboard:dev": "pnpm -F dashboard dev",
        "dashboard:build": "pnpm -F dashboard build",
        "server:dev": "pnpm -F server start:dev",
        "server:debug": "pnpm -F server start:debug",
        "server:build": "pnpm -F server build",
        "server:clean-all-logs": "pnpm -F server clean:all-logs",
        "server:clean-old-logs": "pnpm -F server clean:old-logs",
        "tthree:docs-dev": "pnpm --silent -F tthree docs:dev",
        "tthree:docs-build": "pnpm --silent -F tthree docs:build",
        "tthree:docs-preview": "pnpm --silent -F tthree docs:preview",
        "_clean:all-dists": "echo '🧹 开始清理 dist 目录...' && echo '' && echo '📦 删除 packages 下的 dist...' && find ./packages -type d -name dist -prune -exec rm -rf {} \\; 2>/dev/null || true && echo '✅ packages 下的 dist 已删除' && echo '' && echo '📦 删除 apps 下的 dist...' && find ./apps -type d -name dist -prune -exec rm -rf {} \\; 2>/dev/null || true && echo '✅ apps 下的 dist 已删除' && echo '' && echo '📦 删除根目录 dist...' && rm -rf ./dist 2>/dev/null || true && echo '✅ 根目录 dist 已删除' && echo '' && echo '✅ 清理完成！'",
        "_clean:all-node_modules": "echo '🧹 开始清理 node_modules...' && echo '' && echo '📦 删除根目录 node_modules...' && rm -rf ./node_modules 2>/dev/null || true && echo '✅ 根目录 node_modules 已删除' && echo '' && echo '📦 删除 packages 下的 node_modules...' && find ./packages -type d -name node_modules -prune -exec rm -rf {} \\; 2>/dev/null || true && echo '✅ packages 下的 node_modules 已删除' && echo '' && echo '📦 删除 apps 下的 node_modules...' && find ./apps -type d -name node_modules -prune -exec rm -rf {} \\; 2>/dev/null || true && echo '✅ apps 下的 node_modules 已删除' && echo '' && echo '📄 删除 pnpm-lock.yaml...' && rm -f pnpm-lock.yaml 2>/dev/null || true && echo '✅ pnpm-lock.yaml 已删除' && echo '' && echo '✅ 清理完成！'",
        "clean:all-dists": "pnpm --silent run _clean:all-dists",
        "clean:all-node_modules": "pnpm --silent run _clean:all-node_modules",
        "lint": "eslint",
        "lint:fix": "eslint --fix",
        "docs:dev": "vitepress dev docs --port 9999 --host 0.0.0.0",
        "docs:build": "vitepress build docs",
        "docs:preview": "vitepress preview docs",
        "prepare": "husky",
        "lint:lint-staged": "lint-staged",
        "commit": "git-cz"
    },
    "lint-staged": {
        "*.{js,ts}": [
            "eslint --fix",
            "prettier --write"
        ],
        "*.{cjs,json}": [
            "prettier --write"
        ],
        "*.{vue,html}": [
            "eslint --fix",
            "prettier --write",
            "stylelint --fix"
        ],
        "*.{scss,css}": [
            "prettier --write",
            "stylelint --fix"
        ],
        "*.md": [
            "prettier --write"
        ]
    },
    "config": {
        "commitizen": {
            "path": "node_modules/cz-git"
        }
    },
    "dependencies": {
        "@types/jsonwebtoken": "^9.0.10",
        "axios": "1.13.6",
        "jsonwebtoken": "^9.0.3"
    },
    "pnpm": {
        "peerDependencyRules": {
            "ignoreMissing": [],
            "allowedVersions": {
                "react-lazy-load>react": ">=17",
                "react-lazy-load>react-dom": ">=17"
            }
        }
    },
    "devDependencies": {
        "@commitlint/cli": "^20.5.0",
        "@commitlint/config-conventional": "^20.5.0",
        "@eslint/js": "^10.0.1",
        "commitizen": "^4.3.1",
        "cz-git": "^1.12.0",
        "eslint": "^10.1.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-es5": "^1.5.0",
        "eslint-plugin-prettier": "^5.5.5",
        "eslint-plugin-react-hooks": "^7.0.1",
        "eslint-plugin-react-refresh": "^0.5.2",
        "globals": "^17.4.0",
        "husky": "^9.1.7",
        "init": "^0.1.2",
        "lint-staged": "^16.4.0",
        "postcss-html": "^1.8.1",
        "prettier": "^3.8.1",
        "stylelint": "^17.5.0",
        "stylelint-config-standard": "^40.0.0",
        "typescript": "6.0.2",
        "typescript-eslint": "^8.57.2",
        "vitepress": "^1.6.4"
    }
}
